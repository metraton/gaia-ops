{
  "version": "1.0",
  "reconnaissance_agent": "developer",
  "surfaces": {
    "live_runtime": {
      "intent": "The user needs to inspect, diagnose, or validate the actual state of running systems — pods, services, logs, cloud resources, network connectivity, SSH access, or compare what IS running against what SHOULD be running.",
      "primary_agent": "cloud-troubleshooter",
      "adjacent_surfaces": [
        "gitops_desired_state",
        "terraform_iac"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "infrastructure",
        "orchestration",
        "cluster_details",
        "monitoring_observability",
        "application_services",
        "infrastructure_topology",
        "architecture_overview"
      ],
      "required_checks": [
        "Prefer read-only live validation when runtime state is the question",
        "Capture the exact diagnostic command and the key output that changed your conclusion",
        "Compare actual state against desired state when manifests or IaC are implicated"
      ],
      "signals": {
        "keywords": [
          "live cluster",
          "runtime drift",
          "pod",
          "pods",
          "logs",
          "incident",
          "crashloopbackoff",
          "imagepullbackoff",
          "service unavailable",
          "latency",
          "outage",
          "runtime",
          "remote",
          "transfer",
          "copy to",
          "copy from",
          "WSL",
          "Windows",
          "Metra Tower"
        ],
        "commands": [
          "kubectl",
          "gcloud",
          "aws",
          "eksctl",
          "gsutil",
          "ssh",
          "scp",
          "rsync",
          "sftp",
          "tailscale"
        ],
        "artifacts": [
          "pod",
          "service",
          "ingress",
          "node pool",
          "cluster"
        ]
      }
    },
    "gitops_desired_state": {
      "intent": "The user needs to create, modify, or review the desired state of Kubernetes workloads — Flux HelmReleases, Kustomizations, manifests, Helm values, or any declarative config that defines what SHOULD run in the cluster.",
      "primary_agent": "gitops-operator",
      "adjacent_surfaces": [
        "live_runtime",
        "terraform_iac",
        "app_ci_tooling"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "infrastructure",
        "orchestration",
        "gitops_configuration",
        "cluster_details",
        "application_services",
        "operational_guidelines",
        "architecture_overview"
      ],
      "required_checks": [
        "Search existing manifests and neighboring GitOps resources before proposing changes",
        "Check desired state against runtime symptoms when the task smells like drift",
        "Surface any deployment/runtime contract that another surface must validate"
      ],
      "signals": {
        "keywords": [
          "gitops",
          "flux",
          "helm",
          "kustomize",
          "manifest",
          "deployment",
          "state in git",
          "desired state",
          "helmrelease",
          "kustomization",
          "rollout",
          "configmap",
          "ingress"
        ],
        "commands": [
          "helm",
          "flux",
          "kustomize",
          "kubectl diff",
          "kubectl apply --dry-run"
        ],
        "artifacts": [
          "yaml",
          "manifest",
          "helmrelease",
          "kustomization",
          "deployment",
          "service",
          "ingress"
        ]
      }
    },
    "terraform_iac": {
      "intent": "The user needs to create, modify, review, or validate Infrastructure as Code — Terraform modules, Terragrunt configs, cloud resource definitions (IAM, VPC, buckets), state files, or plan/apply workflows.",
      "primary_agent": "terraform-architect",
      "adjacent_surfaces": [
        "gitops_desired_state",
        "app_ci_tooling",
        "live_runtime"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "infrastructure",
        "orchestration",
        "terraform_infrastructure",
        "infrastructure_topology",
        "cluster_details",
        "application_services",
        "architecture_overview"
      ],
      "required_checks": [
        "Compare against 2-3 sibling modules or stacks before introducing new structure",
        "Call out blast radius when the change touches shared modules, IAM, or stateful resources",
        "State clearly which live/runtime or GitOps surfaces must cross-check the result"
      ],
      "signals": {
        "keywords": [
          "terraform",
          "terragrunt",
          "iac",
          "iam",
          "bucket",
          "state",
          "module",
          "service account",
          "workload identity",
          "secret manager",
          "vpc",
          "subnet",
          "policy"
        ],
        "commands": [
          "terraform",
          "terragrunt",
          "tflint"
        ],
        "artifacts": [
          ".tf",
          ".hcl",
          "module",
          "terragrunt.hcl",
          "provider",
          "backend"
        ]
      }
    },
    "app_ci_tooling": {
      "intent": "The user needs to write, modify, test, or build application code — Node.js/TypeScript or Python, Docker images, CI/CD pipelines, package management, testing frameworks, linting, or developer tooling.",
      "primary_agent": "developer",
      "adjacent_surfaces": [
        "terraform_iac",
        "gitops_desired_state"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "infrastructure",
        "application_services",
        "operational_guidelines",
        "architecture_overview"
      ],
      "required_checks": [
        "Search for existing application, CI, and developer workflow patterns before changing build or runtime behavior",
        "Surface deployment, runtime, or infrastructure implications instead of treating the task as app-only by default",
        "Include exact build, test, or verification commands whenever they informed the conclusion"
      ],
      "signals": {
        "keywords": [
          "ci",
          "cd",
          "pipeline",
          "docker",
          "dockerfile",
          "build",
          "test",
          "lint",
          "package",
          "npm",
          "pnpm",
          "yarn",
          "turbo",
          "turborepo",
          "remote cache",
          "application code",
          "env var",
          "environment variable"
        ],
        "commands": [
          "npm",
          "pnpm",
          "yarn",
          "node",
          "pytest",
          "jest",
          "eslint",
          "prettier",
          "turbo",
          "docker"
        ],
        "artifacts": [
          "package.json",
          "Dockerfile",
          "workflow",
          "pipeline",
          "tests",
          "src/"
        ]
      }
    },
    "planning_specs": {
      "intent": "The user needs to plan a feature, break down requirements, create specs, implementation plans, or task lists using the Spec-Kit workflow.",
      "primary_agent": "speckit-planner",
      "adjacent_surfaces": [
        "app_ci_tooling",
        "gaia_system"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "infrastructure",
        "operational_guidelines",
        "application_services",
        "architecture_overview"
      ],
      "required_checks": [
        "Keep planning artifacts aligned with governance and project context",
        "Tag adjacent surfaces explicitly when the plan crosses infra, runtime, or app boundaries",
        "Do not silently choose an implementation path when multiple valid options remain"
      ],
      "signals": {
        "keywords": [
          "spec",
          "plan",
          "tasks",
          "research",
          "data-model",
          "acceptance criteria",
          "feature breakdown",
          "workflow phase",
          "speckit",
          "specification",
          "specify",
          "task generation",
          "implementation plan",
          "feature planning",
          "pre-implementation",
          "feature spec",
          "task breakdown"
        ],
        "commands": [
          "/speckit.plan",
          "/speckit.tasks",
          "/speckit.init",
          "/speckit.add-task",
          "/speckit.analyze-task"
        ],
        "artifacts": [
          "spec.md",
          "plan.md",
          "tasks.md",
          "research.md",
          "data-model.md",
          "governance.md"
        ]
      }
    },
    "gaia_system": {
      "intent": "The user needs to modify or analyze the Gaia orchestration system itself — hooks, skills, agent definitions, surface routing, security tiers, approval pipelines, contract formats, or system architecture.",
      "primary_agent": "gaia-system",
      "adjacent_surfaces": [
        "app_ci_tooling"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "infrastructure",
        "orchestration",
        "operational_guidelines",
        "architecture_overview"
      ],
      "required_checks": [
        "Keep hooks, skills, templates, and tests aligned as one system",
        "Check for duplicated contract text or diverging runtime/prompt behavior",
        "Call out any cross-agent or cross-hook impact explicitly"
      ],
      "signals": {
        "keywords": [
          "hook",
          "hooks",
          "skill",
          "skills",
          "agent",
          "agents",
          "claude.md",
          "project context",
          "orchestrator",
          "context provider",
          "response contract",
          "pre_tool_use",
          "subagent_stop",
          "gaia",
          "scanner",
          "contract",
          "project-context",
          "project-context.json",
          "dispatch",
          "routing",
          "identity",
          "meta-agent"
        ],
        "commands": [],
        "artifacts": [
          "hooks/",
          "skills/",
          "agents/",
          "templates/",
          "claude.md",
          "project-context.json"
        ]
      }
    },
    "workspace": {
      "intent": "The user needs personal workspace operations — memory management, scheduled tasks, loops, email, cross-machine file transfers, or general automation that no specialist domain covers.",
      "primary_agent": "gaia-operator",
      "adjacent_surfaces": [
        "live_runtime",
        "app_ci_tooling",
        "gaia_system"
      ],
      "contract_sections": [
        "project_identity",
        "stack",
        "git",
        "environment",
        "workspace_repos"
      ],
      "required_checks": [
        "Verify task doesn't belong to a specialist domain before proceeding",
        "Check memory index before creating duplicate entries"
      ],
      "signals": {
        "keywords": [
          "save this",
          "remember this",
          "note this",
          "save to memory",
          "add to memory",
          "update memory",
          "schedule",
          "loop",
          "cron",
          "email",
          "gmail",
          "inbox",
          "file transfer",
          "organize",
          "automate",
          "workspace",
          "personal",
          "general task"
        ],
        "commands": [
          "cron"
        ],
        "artifacts": [
          "crontab"
        ]
      }
    }
  }
}
