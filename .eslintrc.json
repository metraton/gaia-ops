{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "no-var": "error",
    "prefer-const": "warn",
    "no-throw-literal": "error",
    "no-constant-condition": "warn"
  },
  "ignorePatterns": [
    "node_modules/",
    "tests/",
    "hooks/",
    "tools/",
    "**/*.py"
  ]
}
